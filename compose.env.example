# Copy to `.env` next to docker-compose.yml (Docker Compose loads it automatically).
# Never commit `.env` with real secrets.

# Required: MongoDB Atlas (Project → Database → Connect → Drivers).
# Use a user with read/write on your database; include auth DB if you use one.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/taskboard?retryWrites=true&w=majority

JWT_SECRET=replace-with-a-long-random-string
DATABASE_NAME=taskboard

# Browser origins allowed by the API (comma-separated). Include the URL you open in the browser.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Optional Neural assist
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Host port for the nginx frontend (default 8080)
# FRONTEND_PORT=8080
